# LLM API (支持 OpenAI / DeepSeek / GLM-4 / Moonshot 等兼容接口)
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini         # 可选: deepseek-chat, glm-4, moonshot-v1 等

# SMTP 邮件推送配置
SMTP_HOST=smtp.qq.com            # QQ: smtp.qq.com, Gmail: smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@qq.com
SMTP_PASS=your-auth-code         # QQ 邮箱是授权码, Gmail 是 App Password
EMAIL_FROM=${SMTP_USER}          # 必须与 SMTP_USER 一致，留空自动取 SMTP_USER
EMAIL_RECIPIENTS=user@example.com

# 代理 (可选 - GitHub Actions 境外环境访问知乎需要)
# HTTPS_PROXY=http://your-proxy:7890
# HTTP_PROXY=http://your-proxy:7890
